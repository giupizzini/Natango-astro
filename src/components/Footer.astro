---
import generalSettings from '../content/settings/general.json';
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="container footer-grid">
    <div class="footer-info">
      <a href="#" class="footer-logo">
        <img src="/wp-content/uploads/2025/11/logo-natango-no-sf.png" alt="Logo Natango" />
        <span>{generalSettings.siteName}</span>
      </a>
      <p class="footer-description">
        Scuola stabile di Tango Argentino a Roma. Didattica d'eccellenza, eleganza e passione per valorizzare ogni ballerino nel rispetto della tradizione.
      </p>
    </div>

    <div class="footer-nav">
      <h3>Accademia</h3>
      <ul>
        <li><a href="#hero">Home</a></li>
        <li><a href="#corsi-sez">Corsi & Orari</a></li>
        <li><a href="#fdb-sez">Maestri</a></li>
        <li><a href="#sedi-sez">Sedi</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h3>Contatti</h3>
      <p><i class="fas fa-phone-alt"></i> <a href={`tel:${generalSettings.phone.replace(/\s+/g, '')}`}>{generalSettings.phone}</a></p>
      <p><i class="fas fa-envelope"></i> <a href={`mailto:${generalSettings.email}`}>{generalSettings.email}</a></p>
      <p><i class="fab fa-whatsapp"></i> <a href={`https://wa.me/393392737619?text=${encodeURIComponent(generalSettings.whatsappText)}`} target="_blank">Scrivici su WhatsApp</a></p>
    </div>

    <div class="footer-socials-col">
      <h3>Seguici</h3>
      <div class="social-icons">
        <a href={generalSettings.facebookUrl} target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href={generalSettings.instagramUrl} target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href={generalSettings.youtubeUrl} target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-container">
      <p>&copy; {currentYear} {generalSettings.siteName}. Tutti i diritti riservati.</p>
      <p>Sviluppato con stabilità in Astro & Keystatic</p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background-color: #080808;
    border-top: 1px solid var(--border-color);
    padding: 5rem 0 0;
    margin-top: auto;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr 1fr;
    gap: 3rem;
    padding-bottom: 4rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .footer-logo img {
    height: 40px;
    width: auto;
  }

  .footer-logo span {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .footer-description {
    line-height: 1.7;
    max-width: 320px;
  }

  .main-footer h3 {
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
  }

  .footer-nav ul {
    list-style: none;
  }

  .footer-nav li {
    margin-bottom: 0.8rem;
  }

  .footer-nav a:hover {
    color: var(--text-primary);
    padding-left: 4px;
  }

  .footer-contact p {
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .footer-contact a:hover {
    color: var(--text-primary);
  }

  .social-icons {
    display: flex;
    gap: 1rem;
  }

  .social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .social-icons a:hover {
    background-color: var(--accent-gold);
    color: #000000;
    transform: translateY(-3px);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 0;
    font-size: 0.85rem;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 576px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .bottom-container {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
