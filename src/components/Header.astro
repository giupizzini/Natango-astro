---
import generalSettings from '../content/settings/general.json';
---

<header class="main-header">
  <div class="container header-container">
    <a href="/" class="logo">
      <img src="https://natango.org/wp-content/uploads/2025/11/logo-natango-no-sf.png" alt="Logo Natango" />
      <span class="logo-text">{generalSettings.siteName}</span>
    </a>

    <nav class="nav-menu" id="navMenu">
      <ul>
        <li><a href="#hero">Home</a></li>
        <li><a href="#corsi-sez">Corsi</a></li>
        <li><a href="#fdb-sez">Maestri</a></li>
        <li><a href="#sedi-sez">Sedi</a></li>
        <li><a href="#lezione-gratuita-sez" class="btn-primary">Lezione Gratuita</a></li>
      </ul>
      <div class="mobile-socials">
        <a href={generalSettings.facebookUrl} target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href={generalSettings.instagramUrl} target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href={generalSettings.youtubeUrl} target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
        <a href={`https://wa.me/393392737619?text=${encodeURIComponent(generalSettings.whatsappText)}`} target="_blank" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
      </div>
    </nav>

    <div class="header-socials">
      <a href={generalSettings.facebookUrl} target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
      <a href={generalSettings.instagramUrl} target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
      <a href={generalSettings.youtubeUrl} target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      <a href={`https://wa.me/393392737619?text=${encodeURIComponent(generalSettings.whatsappText)}`} target="_blank" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
    </div>

    <button class="menu-toggle" id="menuToggle" aria-label="Apri menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navMenu = document.getElementById('navMenu');
  const header = document.querySelector('.main-header');

  // Gestione apertura menu mobile
  menuToggle?.addEventListener('click', () => {
    menuToggle.classList.toggle('active');
    navMenu?.classList.toggle('active');
    document.body.classList.toggle('no-scroll');
  });

  // Chiusura menu quando si clicca un link
  const navLinks = document.querySelectorAll('.nav-menu a');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      menuToggle?.classList.remove('active');
      navMenu?.classList.remove('active');
      document.body.classList.remove('no-scroll');
    });
  });

  // Effetto header scuro al volo su scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.4rem 0;
    transition: var(--transition);
    background: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5),
                inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
  }

  .main-header.scrolled {
    background: rgba(10, 10, 10, 0.75);
    border-bottom: 1px solid rgba(197, 168, 128, 0.25);
    padding: 0.9rem 0;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.7),
                0 0 20px 0 rgba(197, 168, 128, 0.04),
                inset 0 1px 0 0 rgba(255, 255, 255, 0.08);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .logo img {
    height: 48px;
    width: auto;
    transition: var(--transition);
  }

  .main-header.scrolled .logo img {
    height: 42px;
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .nav-menu ul {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 2rem;
  }

  .nav-menu a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0;
    position: relative;
  }

  .nav-menu a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--accent-gold);
    transition: var(--transition);
  }

  .nav-menu a:hover {
    color: var(--text-primary);
  }

  .nav-menu a:hover::after {
    width: 100%;
  }

  .nav-menu a.btn-primary {
    background-color: var(--accent-red);
    color: var(--text-primary);
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    font-weight: 600;
    transition: var(--transition);
  }

  .nav-menu a.btn-primary:hover {
    background-color: var(--accent-red-hover);
  }

  .nav-menu a.btn-primary::after {
    display: none;
  }

  .header-socials {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .header-socials a {
    color: var(--text-secondary);
    font-size: 1.1rem;
    transition: var(--transition);
  }

  .header-socials a:hover {
    color: var(--accent-gold);
    transform: translateY(-2px);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
  }

  .menu-toggle .bar {
    width: 100%;
    height: 2px;
    background-color: var(--text-primary);
    transition: var(--transition);
  }

  .mobile-socials {
    display: none;
  }

  @media (max-width: 1024px) {
    .header-socials {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }

    .menu-toggle.active .bar:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .menu-toggle.active .bar:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.active .bar:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 320px;
      height: 100vh;
      background: rgba(15, 15, 15, 0.98);
      backdrop-filter: blur(20px);
      box-shadow: -5px 0 25px rgba(0, 0, 0, 0.5);
      padding: 6rem 2rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-menu.active {
      right: 0;
    }

    .nav-menu ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.8rem;
    }

    .nav-menu a {
      font-size: 1.1rem;
    }

    .mobile-socials {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
    }

    .mobile-socials a {
      font-size: 1.3rem;
      color: var(--text-secondary);
    }
  }

  :global(body.no-scroll) {
    overflow: hidden;
  }
</style>
